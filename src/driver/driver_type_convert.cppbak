            return CU_GRAPH_NODE_TYPE_MEMSET;
        default:
            ERROR_INVALID_ENUM();
    }
}

CUDA_EXTERNAL_SEMAPHORE_SIGNAL_PARAMS UPTKExternalSemaphoreSignalParamsToCUDA_EXTERNAL_SEMAPHORE_SIGNAL_PARAMS(struct UPTKExternalSemaphoreSignalParams UPTK_para)
{
    CUDA_EXTERNAL_SEMAPHORE_SIGNAL_PARAMS CU_para;
    CU_para.flags = UPTK_para.flags;
    memcpy(CU_para.reserved, UPTK_para.reserved, sizeof(CU_para.reserved));
    CU_para.params.fence.value = UPTK_para.params.fence.value;
    CU_para.params.keyedMutex.key = UPTK_para.params.keyedMutex.key;
    memcpy(CU_para.params.reserved, UPTK_para.params.reserved, sizeof(CU_para.params.reserved));
    memcpy(&CU_para.params.nvSciSync, &UPTK_para.params.nvSciSync, sizeof(CU_para.params.nvSciSync));
    return CU_para;
}

CUDA_EXTERNAL_SEMAPHORE_WAIT_PARAMS UPTKExternalSemaphoreWaitParamsToCUDA_EXTERNAL_SEMAPHORE_WAIT_PARAMS(struct UPTKExternalSemaphoreWaitParams UPTK_para)
{
    CUDA_EXTERNAL_SEMAPHORE_WAIT_PARAMS CU_para;
    CU_para.flags = UPTK_para.flags;
    memcpy(CU_para.reserved, UPTK_para.reserved, sizeof(CU_para.reserved));
    CU_para.params.fence.value = UPTK_para.params.fence.value;
    CU_para.params.keyedMutex.key = UPTK_para.params.keyedMutex.key;
    CU_para.params.keyedMutex.timeoutMs = UPTK_para.params.keyedMutex.timeoutMs;
    memcpy(CU_para.params.reserved, UPTK_para.params.reserved, sizeof(CU_para.params.reserved));
    memcpy(&CU_para.params.nvSciSync, &UPTK_para.params.nvSciSync, sizeof(CU_para.params.nvSciSync));
    return CU_para;
}

