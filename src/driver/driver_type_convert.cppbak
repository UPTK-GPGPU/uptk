CUsynchronizationPolicy UPTKSynchronizationPolicyToCUsynchronizationPolicy(UPTKSynchronizationPolicy para) {
    switch (para) {
        case UPTKSyncPolicyAuto:
            return CU_SYNC_POLICY_AUTO;
        case UPTKSyncPolicyBlockingSync:
            return CU_SYNC_POLICY_BLOCKING_SYNC;
        case UPTKSyncPolicySpin:
            return CU_SYNC_POLICY_SPIN;
        case UPTKSyncPolicyYield:
            return CU_SYNC_POLICY_YIELD;
        default:
            ERROR_INVALID_ENUM();
    }
}

CUaccessProperty UPTKAccessPropertyToCUaccessProperty(enum UPTKAccessProperty para) {
    switch (para) {
        case UPTKAccessPropertyNormal:
            return CU_ACCESS_PROPERTY_NORMAL;
        case UPTKAccessPropertyPersisting:
            return CU_ACCESS_PROPERTY_PERSISTING;
        case UPTKAccessPropertyStreaming:
            return CU_ACCESS_PROPERTY_STREAMING;
        default:
              ERROR_INVALID_ENUM();
    }
}

void UPTKAccessPolicyWindowToCUaccessPolicyWindow(const struct UPTKAccessPolicyWindow * UPTK_para, CUaccessPolicyWindow * CU_para)
{
    if (nullptr == UPTK_para || nullptr == CU_para) {
        fprintf(stderr, "%s para is nullptr\n", __FUNCTION__);
        abort();
    }
    CU_para->base_ptr = UPTK_para->base_ptr;
