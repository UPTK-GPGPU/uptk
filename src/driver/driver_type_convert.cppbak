            return CU_GRAPH_NODE_TYPE_EXT_SEMAS_SIGNAL;
        case UPTKGraphNodeTypeEventRecord:
            return CU_GRAPH_NODE_TYPE_EVENT_RECORD;
        case UPTKGraphNodeTypeWaitEvent:
            return CU_GRAPH_NODE_TYPE_WAIT_EVENT;
        case UPTKGraphNodeTypeEmpty:
            return CU_GRAPH_NODE_TYPE_EMPTY;
        case UPTKGraphNodeTypeGraph:
            return CU_GRAPH_NODE_TYPE_GRAPH;
        case UPTKGraphNodeTypeHost:
            return CU_GRAPH_NODE_TYPE_HOST;
        case UPTKGraphNodeTypeKernel:
            return CU_GRAPH_NODE_TYPE_KERNEL;
