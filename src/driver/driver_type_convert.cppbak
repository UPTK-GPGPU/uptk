        case UPTKErrorUnknown:
            return CUErrorUnknown;
        case UPTKErrorUnmapBufferObjectFailed:
            return CUErrorUnmapBufferObjectFailed;
        case UPTKErrorUnsupportedLimit:
            return CUErrorUnsupportedLimit;
        case UPTKSuccess:
            return CUSuccess;
        default:
            ERROR_INVALID_ENUM();
    }
}

CUFuncAttribute UPTKFuncAttributeToCUFuncAttribute(enum UPTKFuncAttribute para) {
    switch (para) {
        case UPTKFuncAttributeMax:
            return CUFuncAttributeMax;
        case UPTKFuncAttributeMaxDynamicSharedMemorySize:
            return CUFuncAttributeMaxDynamicSharedMemorySize;
        case UPTKFuncAttributePreferredSharedMemoryCarveout:
            return CUFuncAttributePreferredSharedMemoryCarveout;
        default:
            ERROR_INVALID_ENUM();
    }
}

void CUDevicePropToUPTKDeviceProp(const CUDeviceProp * CU_para, struct UPTKDeviceProp * UPTK_para) {
    if (nullptr == UPTK_para || nullptr == CU_para) {
        fprintf(stderr, "%s para is nullptr\n", __FUNCTION__);
        abort();
    }
    strncpy(UPTK_para->name, CU_para->name, 256);
    UPTK_para->totalGlobalMem = CU_para->totalGlobalMem;
    UPTK_para->sharedMemPerBlock = CU_para->sharedMemPerBlock;
    UPTK_para->regsPerBlock = CU_para->regsPerBlock;
    UPTK_para->warpSize = CU_para->warpSize;
    UPTK_para->maxThreadsPerBlock = CU_para->maxThreadsPerBlock;
    for (int i = 0; i < 3; i++) {
        UPTK_para->maxThreadsDim[i] = CU_para->maxThreadsDim[i];
        UPTK_para->maxGridSize[i] = CU_para->maxGridSize[i];
    }
    UPTK_para->clockRate = CU_para->clockRate;
    UPTK_para->memoryClockRate = CU_para->memoryClockRate;
    UPTK_para->memoryBusWidth = CU_para->memoryBusWidth;
    UPTK_para->totalConstMem = CU_para->totalConstMem;
    UPTK_para->major = SM_VERSION_MAJOR;
    UPTK_para->minor = SM_VERSION_MINOR;
    UPTK_para->multiProcessorCount = CU_para->multiProcessorCount;
    UPTK_para->l2CacheSize = CU_para->l2CacheSize;
    UPTK_para->maxThreadsPerMultiProcessor = CU_para->maxThreadsPerMultiProcessor;
    UPTK_para->computeMode = CU_para->computeMode;
    UPTK_para->concurrentKernels = CU_para->concurrentKernels;
    UPTK_para->pciDomainID = CU_para->pciDomainID;
    UPTK_para->pciBusID = CU_para->pciBusID;
    UPTK_para->pciDeviceID = CU_para->pciDeviceID;

    UPTK_para->sharedMemPerMultiprocessor = CU_para->sharedMemPerMultiprocessor;

    UPTK_para->isMultiGpuBoard = CU_para->isMultiGpuBoard;
    UPTK_para->canMapHostMemory = CU_para->canMapHostMemory;
    UPTK_para->integrated = CU_para->integrated;
    UPTK_para->cooperativeLaunch = CU_para->cooperativeLaunch;
    UPTK_para->cooperativeMultiDeviceLaunch = CU_para->cooperativeMultiDeviceLaunch;

    UPTK_para->maxTexture1D    = CU_para->maxTexture1D;
    UPTK_para->maxTexture2D[0] = CU_para->maxTexture2D[0];
    UPTK_para->maxTexture2D[1] = CU_para->maxTexture2D[1];
    UPTK_para->maxTexture3D[0] = CU_para->maxTexture3D[0];
    UPTK_para->maxTexture3D[1] = CU_para->maxTexture3D[1];
    UPTK_para->maxTexture3D[2] = CU_para->maxTexture3D[2];

    UPTK_para->memPitch                 = CU_para->memPitch;
    UPTK_para->textureAlignment         = CU_para->textureAlignment;
    UPTK_para->texturePitchAlignment    = CU_para->texturePitchAlignment;
    UPTK_para->kernelExecTimeoutEnabled = CU_para->kernelExecTimeoutEnabled;
    UPTK_para->ECCEnabled               = CU_para->ECCEnabled;
    UPTK_para->tccDriver                = CU_para->tccDriver;
    UPTK_para->regsPerMultiprocessor = CU_para->regsPerMultiprocessor;
    UPTK_para->maxBlocksPerMultiProcessor = CU_para->maxBlocksPerMultiProcessor;

    memcpy(&(UPTK_para->uuid), &(CU_para->uuid), sizeof(UPTKUUID_t));
    for(int i = 0; i < 8; i++){
        UPTK_para->luid[i] = CU_para->luid[i];
    }
    UPTK_para->luidDeviceNodeMask = CU_para->luidDeviceNodeMask;
    UPTK_para->deviceOverlap = CU_para->deviceOverlap;
    UPTK_para->maxTexture1DMipmap = CU_para->maxTexture1DMipmap;
    UPTK_para->maxTexture1DLinear = CU_para->maxTexture1DLinear;

    for(int i = 0; i < 2; i++){
    UPTK_para->maxTexture2DMipmap[i] = CU_para->maxTexture2DMipmap[i];
    UPTK_para->maxTexture2DGather[i] = CU_para->maxTexture2DGather[i];
    UPTK_para->maxTexture1DLayered[i] = CU_para->maxTexture1DLayered[i];
    UPTK_para->maxTextureCubemapLayered[i] = CU_para->maxTextureCubemapLayered[i];
    UPTK_para->maxSurface2D[i] = CU_para->maxSurface2D[i];
    UPTK_para->maxSurface1DLayered[i] = CU_para->maxSurface1DLayered[i];
    UPTK_para->maxSurfaceCubemapLayered[i] = CU_para->maxSurfaceCubemapLayered[i];

    }

    UPTK_para->maxSurface1D = CU_para->maxSurface1D;

    for(int i = 0; i < 3; i++){
    UPTK_para->maxTexture2DLinear[i] = CU_para->maxTexture2DLinear[i];
    UPTK_para->maxTexture3DAlt[i] = CU_para->maxTexture3DAlt[i];
    UPTK_para->maxTextureCubemap = CU_para->maxTextureCubemap;
    UPTK_para->maxTexture2DLayered[i] = CU_para->maxTexture2DLayered[i];
    UPTK_para->maxSurface3D[i] = CU_para->maxSurface3D[i];
    UPTK_para->maxSurface2DLayered[i] = CU_para->maxSurface2DLayered[i];
    }

    UPTK_para->maxSurfaceCubemap = CU_para->maxSurfaceCubemap;
    UPTK_para->surfaceAlignment = CU_para->surfaceAlignment;
    UPTK_para->asyncEngineCount = CU_para->asyncEngineCount;
    UPTK_para->unifiedAddressing = 1;
    UPTK_para->persistingL2CacheMaxSize = CU_para->persistingL2CacheMaxSize;
    UPTK_para->streamPrioritiesSupported = CU_para->streamPrioritiesSupported;
    UPTK_para->globalL1CacheSupported = CU_para->globalL1CacheSupported;
    UPTK_para->localL1CacheSupported = CU_para->localL1CacheSupported;
    UPTK_para->managedMemory = CU_para->managedMemory;
    UPTK_para->multiGpuBoardGroupID = CU_para->multiGpuBoardGroupID;
    UPTK_para->hostNativeAtomicSupported = CU_para->hostNativeAtomicSupported;
    UPTK_para->singleToDoublePrecisionPerfRatio = CU_para->singleToDoublePrecisionPerfRatio;
    UPTK_para->pageableMemoryAccess = CU_para->pageableMemoryAccess;
    UPTK_para->concurrentManagedAccess = CU_para->concurrentManagedAccess;
    UPTK_para->computePreemptionSupported = CU_para->computePreemptionSupported;
    UPTK_para->canUseHostPointerForRegisteredMem = CU_para->canUseHostPointerForRegisteredMem;
    UPTK_para->sharedMemPerBlockOptin = CU_para->sharedMemPerBlockOptin;
    UPTK_para->pageableMemoryAccessUsesHostPageTables = CU_para->pageableMemoryAccessUsesHostPageTables;
    UPTK_para->directManagedMemAccessFromHost = CU_para->directManagedMemAccessFromHost;
    UPTK_para->accessPolicyMaxWindowSize = CU_para->accessPolicyMaxWindowSize;
    UPTK_para->reservedSharedMemPerBlock = CU_para->reservedSharedMemPerBlock;
}*/

#if defined(__cplusplus)
}
#endif /* __cplusplus */
