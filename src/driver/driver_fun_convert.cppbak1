__host__ UPTKError_t UPTKStreamWaitEvent(UPTKStream_t stream, UPTKEvent_t event, unsigned int flags) {
    CUresult cu_res = cuStreamWaitEvent((CUstream)stream, (CUevent)event, flags);
    return CUresultToUPTKresult(cu_res);
}

__host__ UPTKError_t UPTKStreamBeginCapture(UPTKStream_t stream, enum UPTKStreamCaptureMode mode) {
    if (mode < UPTKStreamCaptureModeGlobal || mode > UPTKStreamCaptureModeRelaxed) {
        return UPTKErrorInvalidValue;
    }
    CUstreamCaptureMode cu_mode = (CUstreamCaptureMode)mode;  // Direct cast assuming compatibility
    CUresult cu_res = cuStreamBeginCapture((CUstream)stream, cu_mode);
    return CUresultToUPTKresult(cu_res);
}

__host__ UPTKError_t UPTKStreamEndCapture(UPTKStream_t stream, UPTKGraph_t * pGraph) {
    CUresult cu_res = cuStreamEndCapture((CUstream)stream, (CUgraph*)pGraph);
    return CUresultToUPTKresult(cu_res);
}

__host__ UPTKError_t UPTKStreamIsCapturing(UPTKStream_t stream, enum UPTKStreamCaptureStatus * pCaptureStatus) {
    if (nullptr == pCaptureStatus) return UPTKErrorInvalidValue;
    CUstreamCaptureStatus cu_status;
    CUresult cu_res = cuStreamIsCapturing((CUstream)stream, &cu_status);
    *pCaptureStatus = (enum UPTKStreamCaptureStatus)cu_status;
    return CUresultToUPTKresult(cu_res);
}

