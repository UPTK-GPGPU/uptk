__host__ UPTKError_t  UPTKGraphNodeGetType(UPTKGraphNode_t node,enum UPTKGraphNodeType * pType)
{
    if (nullptr == pType)
        return UPTKErrorInvalidValue;
    CUGraphNodeType CU_pType;
    CUError_t CU_res;
    CU_res = CUGraphNodeGetType((CUGraphNode_t) node, &CU_pType);
    if (CUSuccess == CU_res)
        *pType = CUGraphNodeTypeToUPTKGraphNodeType(CU_pType);
    return CUErrorToUPTKError(CU_res);
}

