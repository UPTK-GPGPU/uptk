    CU_res = CULaunchKernel(func, gridDim, blockDim, args, sharedMem, (CUStream_t)stream);
    return CUErrorToUPTKError(CU_res);
}

__host__  UPTKError_t  UPTKFuncGetAttributes(struct UPTKFuncAttributes * attr,const void * func)
{
    if(nullptr == attr)
    {
        return UPTKErrorInvalidValue;
    }

    memset(attr, 0, sizeof(UPTKFuncAttributes));

    struct CUFuncAttributes CU_attr;
    memset(&CU_attr, 0, sizeof(CUFuncAttributes));

    CUError_t CU_res;
    CU_res = CUFuncGetAttributes(&CU_attr, func);
    if ( CU_res == CUSuccess )
    {
        CUFuncAttributesToUPTKFuncAttributes(&CU_attr, attr);
    }
    return CUErrorToUPTKError(CU_res);
}

